   ],
   "source": [
    "print(\"=== ДЕТАЛЬНАЯ ИНФОРМАЦИЯ ОБ ОБЪЕКТАХ ===\")\n",
    "detailed_info = conn.execute(\"\"\"--sql\n",
    "    SELECT \n",
    "        table_name,\n",
    "        table_type,\n",
    "        table_schema\n",
    "    FROM information_schema.tables\n",
    "    WHERE table_name = 'salaries'\n",
    "\"\"\").fetchdf()\n",
    "print(detailed_info)"
   ]
